{
  "name": "photo-gallery",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');const d='node_modules/react-native-worklets';fs.mkdirSync(d,{recursive:true});fs.writeFileSync(d+'/package.json',JSON.stringify({name:'react-native-worklets',version:'1.0.0',main:'./index.js'}));fs.writeFileSync(d+'/index.js',\\\"module.exports=require('react-native-worklets-core');\\\");fs.writeFileSync(d+'/plugin.js',\\\"module.exports=require('react-native-worklets-core/plugin');\\\")\"",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "test": "jest --watchAll=false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "clsx": "^2.1.1",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.0",
    "expo-linking": "~55.0.0",
    "expo-router": "~55.0.0",
    "expo-status-bar": "~2.2.0",
    "nativewind": "^4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.20.0",
    "react-native-worklets-core": "^1.6.3",
    "react-refresh": "^0.14.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-preset-expo": "~13.0.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/react": "~19.1.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.7.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/(?!metro)|@expo-google-fonts|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|nativewind|tailwindcss)"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": false
      }
    }
  }
}
